---
interface Props {
  artistName: string;
}
const { artistName } = Astro.props;
const pathname = Astro.url.pathname;
---

<nav class="site-nav">
  <ul class="site-nav__links">
    <li>
      <a href="/" aria-current={pathname === '/' ? 'page' : undefined}>
        Home
      </a>
    </li>
    <li>
      <a href="/gallery" aria-current={pathname.startsWith('/gallery') ? 'page' : undefined}>
        Gallery
      </a>
    </li>
    <li>
      <a href="/about" aria-current={pathname === '/about' ? 'page' : undefined}>
        About
      </a>
    </li>
  </ul>

  <a href="/" class="site-nav__brand">{artistName}</a>

  <div class="site-nav__right">
    <button class="cart-btn" id="cart-toggle" aria-label="Open shopping cart">
      Cart
      <span class="cart-count" id="cart-count" hidden>0</span>
    </button>
  </div>
</nav>
