---
interface Props {
  artistName: string;
  tagline: string;
  heroText: string;
  heroVideoUrl?: string;
  featuredImageUrl?: string;
  featuredImageTitle?: string;
  featuredSlug?: string;
}

const {
  artistName,
  tagline,
  heroText,
  heroVideoUrl,
  featuredImageUrl,
  featuredImageTitle,
  featuredSlug,
} = Astro.props;

const hasBackground = heroVideoUrl || featuredImageUrl;
---

<section class="hero">
  {heroVideoUrl ? (
    <div class="hero__image-wrap">
      <video
        class="hero__video"
        autoplay
        muted
        loop
        playsinline
        aria-hidden="true"
      >
        <source src={heroVideoUrl} type={heroVideoUrl.endsWith('.webm') ? 'video/webm' : 'video/mp4'} />
      </video>
    </div>
  ) : featuredImageUrl ? (
    <div class="hero__image-wrap">
      <img src={featuredImageUrl} alt={featuredImageTitle || artistName} />
    </div>
  ) : null}

  {hasBackground && <div class="hero__overlay"></div>}

  <div class={`hero__content${hasBackground ? '' : ' hero__content--dark'}`}>
    <p class="hero__tagline">{tagline || 'Original artwork'}</p>
    <h1 class="hero__title">{artistName}</h1>
    {heroText && <p class="hero__text">{heroText}</p>}
    {hasBackground && featuredSlug ? (
      <a href={`/gallery/${featuredSlug}`} class="hero__cta">View work</a>
    ) : (
      <a href="/gallery" class="hero__cta">Explore gallery</a>
    )}
  </div>
</section>
