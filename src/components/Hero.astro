---
interface Props {
  artistName: string;
  tagline: string;
  heroText: string;
  heroVideoUrl?: string;
  heroImageUrl?: string;
  featuredImageUrl?: string;
  featuredImageTitle?: string;
  featuredSlug?: string;
}

const {
  artistName,
  tagline,
  heroText,
  heroVideoUrl,
  heroImageUrl,
  featuredImageUrl,
  featuredImageTitle,
  featuredSlug,
} = Astro.props;

// Priority: video > custom hero image > first featured artwork
const bgImage = heroImageUrl || featuredImageUrl;
const hasBackground = heroVideoUrl || bgImage;
const bgAlt = heroImageUrl ? artistName : (featuredImageTitle || artistName);
---

<section class="hero">
  {heroVideoUrl ? (
    <div class="hero__image-wrap">
      <video
        class="hero__video"
        autoplay
        muted
        loop
        playsinline
        aria-hidden="true"
      >
        <source src={heroVideoUrl} type={heroVideoUrl.endsWith('.webm') ? 'video/webm' : 'video/mp4'} />
      </video>
    </div>
  ) : bgImage ? (
    <div class="hero__image-wrap">
      <img src={bgImage} alt={bgAlt} />
    </div>
  ) : null}

  {hasBackground && <div class="hero__overlay"></div>}

  <div class={`hero__content${hasBackground ? '' : ' hero__content--dark'}`}>
    <p class="hero__tagline">{tagline || 'Original artwork'}</p>
    <h1 class="hero__title">{artistName}</h1>
    {heroText && <p class="hero__text">{heroText}</p>}
    {!heroVideoUrl && !heroImageUrl && featuredSlug ? (
      <a href={`/gallery/${featuredSlug}`} class="hero__cta">View work</a>
    ) : (
      <a href="/gallery" class="hero__cta">Explore gallery</a>
    )}
  </div>
</section>
