---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { connectDB } from '../../../lib/db';
import { SiteContent } from '../../../lib/models/SiteContent';

await connectDB();
const content = await SiteContent.findOne({ key: 'homepage' }).lean();
const success = Astro.url.searchParams.get('success');
const error = Astro.url.searchParams.get('error');

const videoFilename = content?.heroVideoUrl?.split('/').pop() ?? '';
const imageFilename = content?.heroImageUrl?.split('/').pop() ?? '';
---

<AdminLayout title="Homepage Content">
  <div class="admin-header">
    <h1 class="admin-title">Homepage Content</h1>
  </div>

  {success && <div class="alert alert--success">Saved successfully.</div>}
  {error && <div class="alert alert--error">Failed to save. Please try again.</div>}

  <form
    class="admin-form"
    method="POST"
    action="/api/content/homepage"
    enctype="multipart/form-data"
    style="max-width:860px;"
  >
    <input type="hidden" name="_method" value="PUT" />

    <div class="form-grid">

      <!-- ══ Section 1: Splash image ══ -->
      <div class="form-group form-group--full">
        <p class="section-label">
          <span class="section-num">1</span>
          Full-screen image
        </p>
        <p class="form-hint">
          Displayed as a full-viewport image at the top of the homepage.
          Choose a video <em>or</em> a photo (video takes priority).
          Leave both empty to use the first featured artwork as fallback.
        </p>
      </div>

      <!-- Splash preview -->
      {(content?.heroImageUrl || content?.heroVideoUrl) && (
        <div class="form-group form-group--full">
          <div class="splash-preview">
            <div class="splash-preview__media">
              {content.heroVideoUrl ? (
                <video src={content.heroVideoUrl} muted autoplay loop playsinline />
              ) : (
                <img src={content.heroImageUrl} alt="Section 1 preview" />
              )}
            </div>
            <div class="splash-preview__overlay"></div>
            <p class="splash-preview__label">Section 1 — Splash</p>
          </div>
          <p class="form-hint" style="margin-top:0.5rem;">Save to refresh preview.</p>
        </div>
      )}

      <!-- Background Photo -->
      <div class="form-group form-group--full hero-bg-block">
        <label class="form-label">Background Photo</label>

        {content?.heroImageUrl ? (
          <div style="margin-bottom:0.75rem;">
            <img
              src={content.heroImageUrl}
              alt="Current splash photo"
              style="max-width:360px;width:100%;border-radius:4px;border:1px solid var(--border);object-fit:cover;max-height:200px;"
            />
            <p class="form-hint" style="margin-top:0.375rem;">{imageFilename}</p>
          </div>
          <label class="form-check" style="margin-bottom:0.75rem;">
            <input type="checkbox" name="removeHeroImage" value="1" />
            Remove current photo
          </label>
        ) : (
          <p class="form-hint" style="margin-bottom:0.5rem;">No photo set.</p>
        )}

        <input
          class="form-input"
          type="file"
          name="heroImage"
          accept="image/jpeg,image/png,image/webp"
          style="padding:0.375rem 0.5rem;"
        />
        <p class="form-hint">JPEG, PNG or WebP</p>
      </div>

      <!-- Background Video -->
      <div class="form-group form-group--full hero-bg-block">
        <label class="form-label">
          Background Video
          <span class="badge badge--gold" style="vertical-align:middle;font-size:0.6rem;margin-left:0.375rem;">takes priority over photo</span>
        </label>

        {content?.heroVideoUrl ? (
          <div style="margin-bottom:0.75rem;">
            <video
              src={content.heroVideoUrl}
              muted
              controls
              style="max-width:360px;width:100%;border-radius:4px;border:1px solid var(--border);"
            />
            <p class="form-hint" style="margin-top:0.375rem;">{videoFilename}</p>
          </div>
          <label class="form-check" style="margin-bottom:0.75rem;">
            <input type="checkbox" name="removeVideo" value="1" />
            Remove current video
          </label>
        ) : (
          <p class="form-hint" style="margin-bottom:0.5rem;">No video set.</p>
        )}

        <input
          class="form-input"
          type="file"
          name="heroVideo"
          accept="video/mp4,video/webm"
          style="padding:0.375rem 0.5rem;"
        />
        <p class="form-hint">
          MP4 or WebM &middot; Max 30 MB &middot; 5–15 s recommended &middot; No audio required
        </p>
      </div>

      <!-- ══ Section 2: Intro text ══ -->
      <div class="form-group form-group--full" style="margin-top:1rem;">
        <p class="section-label">
          <span class="section-num">2</span>
          Intro text
        </p>
        <p class="form-hint">
          Displayed on the cream-background section below the splash image.
        </p>
      </div>

      <!-- Intro preview -->
      <div class="form-group form-group--full">
        <div class="intro-preview">
          {content?.tagline && <p class="intro-preview__tagline">{content.tagline}</p>}
          <p class="intro-preview__title">{content?.artistName || 'Artist Name'}</p>
          {content?.heroText && <p class="intro-preview__text">{content.heroText}</p>}
          <span class="intro-preview__cta">Explore Gallery</span>
        </div>
        <p class="form-hint" style="margin-top:0.5rem;">Save to refresh preview.</p>
      </div>

      <div class="form-group form-group--full">
        <label class="form-label" for="artistName">Artist Name</label>
        <input
          class="form-input"
          type="text"
          id="artistName"
          name="artistName"
          value={content?.artistName || ''}
          placeholder="e.g. Marie Dupont"
        />
        <p class="form-hint">Also shown in the navigation bar.</p>
      </div>

      <div class="form-group form-group--full">
        <label class="form-label" for="tagline">Tagline</label>
        <input
          class="form-input"
          type="text"
          id="tagline"
          name="tagline"
          value={content?.tagline || ''}
          placeholder="e.g. Original drawings & fine art photography"
        />
        <p class="form-hint">Small uppercase label above the artist name.</p>
      </div>

      <div class="form-group form-group--full">
        <label class="form-label" for="heroText">Description</label>
        <textarea
          class="form-textarea"
          id="heroText"
          name="heroText"
          rows="4"
          placeholder="A short paragraph describing your work or practice."
        >{content?.heroText || ''}</textarea>
      </div>

      <!-- ══ Other ══ -->
      <div class="form-group form-group--full" style="margin-top:1rem;">
        <p class="section-label" style="background:none;border:none;padding:0;">
          <span class="section-num" style="background:var(--border-strong);color:var(--text);">↗</span>
          Social & links
        </p>
      </div>

      <div class="form-group form-group--full">
        <label class="form-label" for="instagramUrl">Instagram URL</label>
        <input
          class="form-input"
          type="url"
          id="instagramUrl"
          name="instagramUrl"
          value={content?.instagramUrl || ''}
          placeholder="https://www.instagram.com/yourusername"
        />
        <p class="form-hint">Shown in the bottom contact section and footer. Leave empty to hide.</p>
      </div>

    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn--primary">Save Changes</button>
    </div>
  </form>
</AdminLayout>

<style>
  .section-label {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.78125rem;
    letter-spacing: 0.05em;
    font-weight: 500;
    color: var(--text);
    text-transform: uppercase;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.625rem;
    margin-bottom: 0.25rem;
  }

  .section-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.375rem;
    height: 1.375rem;
    border-radius: 50%;
    background: var(--bg-dark);
    color: #fff;
    font-size: 0.6875rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .hero-bg-block {
    background: #FAFAF9;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.25rem;
  }

  /* Section 1 splash preview */
  .splash-preview {
    position: relative;
    height: 200px;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-dark);
  }

  .splash-preview__media {
    position: absolute;
    inset: 0;
  }

  .splash-preview__media img,
  .splash-preview__media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .splash-preview__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(10,8,6,0.15) 0%, rgba(10,8,6,0.1) 60%, rgba(10,8,6,0.3) 100%);
  }

  .splash-preview__label {
    position: absolute;
    bottom: 0.75rem;
    left: 0.875rem;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    background: rgba(0,0,0,0.35);
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
  }

  /* Section 2 intro preview */
  .intro-preview {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 2rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .intro-preview__tagline {
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .intro-preview__title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--text);
  }

  .intro-preview__text {
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.65;
    max-width: 48ch;
  }

  .intro-preview__cta {
    display: inline-block;
    margin-top: 0.25rem;
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--text);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text);
    width: fit-content;
  }
</style>
