---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { connectDB } from '../../../lib/db';
import { SiteContent } from '../../../lib/models/SiteContent';

await connectDB();
const content = await SiteContent.findOne({ key: 'homepage' }).lean();
const success = Astro.url.searchParams.get('success');
const error = Astro.url.searchParams.get('error');

const videoFilename = content?.heroVideoUrl?.split('/').pop() ?? '';
const imageFilename = content?.heroImageUrl?.split('/').pop() ?? '';
---

<AdminLayout title="Homepage Content">
  <div class="admin-header">
    <h1 class="admin-title">Homepage Content</h1>
  </div>

  {success && <div class="alert alert--success">Saved successfully.</div>}
  {error && <div class="alert alert--error">Failed to save. Please try again.</div>}

  <form
    class="admin-form"
    method="POST"
    action="/api/content/homepage"
    enctype="multipart/form-data"
    style="max-width:860px;"
  >
    <input type="hidden" name="_method" value="PUT" />

    <div class="form-grid">

      <!-- Text fields -->
      <div class="form-group form-group--full">
        <label class="form-label" for="artistName">Artist Name</label>
        <input
          class="form-input"
          type="text"
          id="artistName"
          name="artistName"
          value={content?.artistName || ''}
          placeholder="e.g. Marie Dupont"
        />
        <p class="form-hint">Displayed in the navigation and hero section.</p>
      </div>

      <div class="form-group form-group--full">
        <label class="form-label" for="tagline">Tagline</label>
        <input
          class="form-input"
          type="text"
          id="tagline"
          name="tagline"
          value={content?.tagline || ''}
          placeholder="e.g. Original drawings & fine art photography"
        />
      </div>

      <div class="form-group form-group--full">
        <label class="form-label" for="instagramUrl">Instagram URL</label>
        <input
          class="form-input"
          type="url"
          id="instagramUrl"
          name="instagramUrl"
          value={content?.instagramUrl || ''}
          placeholder="https://www.instagram.com/yourusername"
        />
        <p class="form-hint">Shown in the site footer. Leave empty to hide the Instagram link.</p>
      </div>

      <div class="form-group form-group--full">
        <label class="form-label" for="heroText">Hero Text</label>
        <textarea
          class="form-textarea"
          id="heroText"
          name="heroText"
          rows="4"
          placeholder="A short paragraph shown on the homepage hero."
        >{content?.heroText || ''}</textarea>
      </div>

      <!-- Hero preview -->
      {(content?.heroImageUrl || content?.heroVideoUrl) && (
        <div class="form-group form-group--full">
          <p class="form-section-title" style="margin-bottom:0.75rem;">Hero Preview</p>
          <div class="hero-preview">
            <div class="hero-preview__bg">
              {content.heroVideoUrl ? (
                <video src={content.heroVideoUrl} muted autoplay loop playsinline />
              ) : (
                <img src={content.heroImageUrl} alt="Hero background preview" />
              )}
            </div>
            <div class="hero-preview__overlay"></div>
            <div class="hero-preview__content">
              {content.tagline && <p class="hero-preview__tagline">{content.tagline}</p>}
              <p class="hero-preview__title">{content.artistName || 'Artist Name'}</p>
              {content.heroText && <p class="hero-preview__text">{content.heroText}</p>}
            </div>
          </div>
          <p class="form-hint" style="margin-top:0.5rem;">Save changes to refresh this preview.</p>
        </div>
      )}

      <!-- Hero background divider -->
      <div class="form-group form-group--full">
        <p class="form-section-title">Hero Background</p>
        <p class="form-hint">
          Choose a video <em>or</em> a photo. If both are set, the video takes priority.
          Leave both empty to use the first featured artwork as background.
        </p>
      </div>

      <!-- Hero Photo -->
      <div class="form-group form-group--full hero-bg-block">
        <label class="form-label">Background Photo</label>

        {content?.heroImageUrl ? (
          <div style="margin-bottom:0.75rem;">
            <img
              src={content.heroImageUrl}
              alt="Current hero photo"
              style="max-width:360px;width:100%;border-radius:4px;border:1px solid var(--border);object-fit:cover;max-height:200px;"
            />
            <p class="form-hint" style="margin-top:0.375rem;">{imageFilename}</p>
          </div>
          <label class="form-check" style="margin-bottom:0.75rem;">
            <input type="checkbox" name="removeHeroImage" value="1" />
            Remove current photo
          </label>
        ) : (
          <p class="form-hint" style="margin-bottom:0.5rem;">No photo set.</p>
        )}

        <input
          class="form-input"
          type="file"
          name="heroImage"
          accept="image/jpeg,image/png,image/webp"
          style="padding:0.375rem 0.5rem;"
        />
        <p class="form-hint">JPEG, PNG or WebP</p>
      </div>

      <!-- Hero Video -->
      <div class="form-group form-group--full hero-bg-block">
        <label class="form-label">Background Video <span class="badge badge--gold" style="vertical-align:middle;font-size:0.6rem;">takes priority over photo</span></label>

        {content?.heroVideoUrl ? (
          <div style="margin-bottom:0.75rem;">
            <video
              src={content.heroVideoUrl}
              muted
              controls
              style="max-width:360px;width:100%;border-radius:4px;border:1px solid var(--border);"
            />
            <p class="form-hint" style="margin-top:0.375rem;">{videoFilename}</p>
          </div>
          <label class="form-check" style="margin-bottom:0.75rem;">
            <input type="checkbox" name="removeVideo" value="1" />
            Remove current video
          </label>
        ) : (
          <p class="form-hint" style="margin-bottom:0.5rem;">No video set.</p>
        )}

        <input
          class="form-input"
          type="file"
          name="heroVideo"
          accept="video/mp4,video/webm"
          style="padding:0.375rem 0.5rem;"
        />
        <p class="form-hint">
          MP4 or WebM &middot; Max 30 MB &middot; 5–15 s recommended &middot; No audio required
        </p>
      </div>

    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn--primary">Save Changes</button>
    </div>
  </form>
</AdminLayout>

<style>
  .form-section-title {
    font-size: 0.78125rem;
    letter-spacing: 0.05em;
    font-weight: 500;
    color: var(--text);
    text-transform: uppercase;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .hero-bg-block {
    background: #FAFAF9;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.25rem;
  }

  .hero-preview {
    position: relative;
    height: 220px;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .hero-preview__bg {
    position: absolute;
    inset: 0;
  }

  .hero-preview__bg img,
  .hero-preview__bg video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-preview__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(10, 8, 6, 0.6) 0%, transparent 75%);
  }

  .hero-preview__content {
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem;
    color: #fff;
  }

  .hero-preview__tagline {
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.9;
    margin-bottom: 0.375rem;
  }

  .hero-preview__title {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 600;
    line-height: 1.15;
    text-shadow: 0 2px 8px rgba(0,0,0,0.4);
    margin-bottom: 0.375rem;
  }

  .hero-preview__text {
    font-size: 0.75rem;
    opacity: 0.85;
    max-width: 280px;
    line-height: 1.55;
  }
</style>
