---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { connectDB } from '../../../lib/db';
import { SiteContent } from '../../../lib/models/SiteContent';

await connectDB();
const content = await SiteContent.findOne({ key: 'about' }).lean();
const success = Astro.url.searchParams.get('success');
const error = Astro.url.searchParams.get('error');
---

<AdminLayout title="About Page">
  <div class="admin-header">
    <h1 class="admin-title">About Page</h1>
  </div>

  {success && <div class="alert alert--success">Saved successfully.</div>}
  {error && <div class="alert alert--error">Failed to save. Please try again.</div>}

  <form
    class="admin-form"
    method="POST"
    action="/api/content/about"
    enctype="multipart/form-data"
  >
    <input type="hidden" name="_method" value="PUT" />

    <div class="form-grid">
      {content?.aboutPortraitUrl && (
        <div class="form-group form-group--full">
          <label class="form-label">Current Portrait</label>
          <img
            src={content.aboutPortraitUrl}
            alt="Portrait"
            style="height:140px;width:auto;border:1px solid var(--border);border-radius:2px;"
          />
        </div>
      )}

      <div class="form-group form-group--full">
        <label class="form-label" for="portrait">
          {content?.aboutPortraitUrl ? 'Replace Portrait Image' : 'Portrait Image'}
        </label>
        <input
          class="form-input"
          type="file"
          id="portrait"
          name="portrait"
          accept="image/*"
        />
        <p class="form-hint">Automatically resized. Displayed alongside the biography.</p>
      </div>

      <div class="form-group form-group--full">
        <label class="form-label" for="aboutBio">Biography</label>
        <textarea
          class="form-textarea"
          id="aboutBio"
          name="aboutBio"
          rows="12"
          placeholder="Write the artist biography here. Line breaks are preserved."
          style="min-height:200px;"
        >{content?.aboutBio || ''}</textarea>
        <p class="form-hint">Line breaks are preserved in the display.</p>
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn--primary">Save Changes</button>
    </div>
  </form>
</AdminLayout>
