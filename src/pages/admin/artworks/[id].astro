---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { connectDB } from '../../../lib/db';
import { Artwork } from '../../../lib/models/Artwork';

const { id } = Astro.params;
await connectDB();
const artwork = await Artwork.findById(id).lean();

if (!artwork) return Astro.redirect('/admin/artworks');

const success = Astro.url.searchParams.get('success');
const currentYear = new Date().getFullYear();
const printSizesJson = JSON.stringify(artwork.printSizes || []);
---

<AdminLayout title={`Edit: ${artwork.title}`}>
  <div class="admin-header">
    <h1 class="admin-title" style="font-size:1.5rem;">Edit: {artwork.title}</h1>
    <div style="display:flex;gap:0.75rem;">
      <a href={`/gallery/${artwork.slug}`} target="_blank" class="btn btn--ghost">↗ View</a>
      <a href="/admin/artworks" class="btn btn--ghost">← Back</a>
    </div>
  </div>

  {success && (
    <div class="alert alert--success">Artwork updated successfully.</div>
  )}

  <form
    class="admin-form"
    method="POST"
    action={`/api/artworks/${id}`}
    enctype="multipart/form-data"
    id="artwork-form"
  >
    <input type="hidden" name="_method" value="PUT" />

    <div class="form-grid">
      <div class="form-group form-group--full">
        <label class="form-label">Current Image</label>
        <img src={artwork.thumbnailUrl} alt={artwork.title}
          style="height:100px;width:auto;border:1px solid var(--border);border-radius:2px;margin-bottom:0.5rem;" />
        <label class="form-label" for="image">Replace Image (optional)</label>
        <input class="form-input" type="file" id="image" name="image" accept="image/*" />
        <p class="form-hint">Leave empty to keep the current image.</p>
      </div>

      <div class="form-group form-group--full">
        <label class="form-label" for="title">Title *</label>
        <input class="form-input" type="text" id="title" name="title" value={artwork.title} required />
      </div>

      <div class="form-group">
        <label class="form-label" for="category">Category *</label>
        <select class="form-select" id="category" name="category" required>
          <option value="drawing" selected={artwork.category === 'drawing'}>Drawing</option>
          <option value="photo" selected={artwork.category === 'photo'}>Photography</option>
        </select>
      </div>

      <div class="form-group">
        <label class="form-label" for="medium">Medium</label>
        <input class="form-input" type="text" id="medium" name="medium" value={artwork.medium} />
      </div>

      <div class="form-group">
        <label class="form-label" for="year">Year</label>
        <input class="form-input" type="number" id="year" name="year" value={artwork.year} min="1900" max={currentYear + 1} />
      </div>

      <div class="form-group">
        <label class="form-label" for="price">Original Price (€)</label>
        <input class="form-input" type="number" id="price" name="price"
          value={artwork.price != null ? artwork.price : ''} min="0" step="0.01"
          placeholder="Leave empty if not for sale" />
      </div>

      <div class="form-group form-group--full">
        <label class="form-label" for="description">Description</label>
        <textarea class="form-textarea" id="description" name="description" rows="5">{artwork.description}</textarea>
      </div>

      <div class="form-group form-group--full">
        <label class="form-label">Print Sizes</label>
        <div class="print-sizes-editor" id="print-sizes-editor"></div>
        <button type="button" class="btn btn--ghost" style="margin-top:0.5rem;font-size:0.8125rem;" onclick="addPrintSize()">
          + Add print size
        </button>
        <input type="hidden" id="printSizes" name="printSizes" value={printSizesJson} />
      </div>

      <div class="form-group form-group--full">
        <label class="form-label" for="tags">Tags</label>
        <input class="form-input" type="text" id="tags" name="tags" value={artwork.tags.join(', ')} placeholder="Comma-separated" />
      </div>

      <div class="form-group">
        <label class="form-check">
          <input type="checkbox" name="available" checked={artwork.available} />
          Available for sale
        </label>
      </div>

      <div class="form-group">
        <label class="form-check">
          <input type="checkbox" name="featured" checked={artwork.featured} />
          Featured on homepage
        </label>
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn--primary">Save Changes</button>
      <a href="/admin/artworks" class="btn btn--ghost">Cancel</a>

      <form method="POST" action={`/api/artworks/${id}`} style="margin-left:auto;"
        onsubmit="return confirm('Delete this artwork? This cannot be undone.')">
        <input type="hidden" name="_method" value="DELETE" />
        <button type="submit" class="btn btn--danger">Delete</button>
      </form>
    </div>
  </form>
</AdminLayout>

<script define:vars={{ initialPrintSizes: artwork.printSizes }}>
  let printSizes = initialPrintSizes ? [...initialPrintSizes] : [];

  function renderPrintSizes() {
    const editor = document.getElementById('print-sizes-editor');
    const input = document.getElementById('printSizes');
    if (!editor || !input) return;
    editor.innerHTML = '';
    printSizes.forEach((ps, i) => {
      const row = document.createElement('div');
      row.className = 'print-size-entry';
      row.innerHTML = `
        <input class="form-input" type="text" placeholder="A4 (21×30 cm)" value="${ps.label}"
          oninput="updatePrintSize(${i}, 'label', this.value)" />
        <input class="form-input" type="number" placeholder="Price €" value="${ps.price}"
          oninput="updatePrintSize(${i}, 'price', parseFloat(this.value)||0)" min="0" step="0.01" />
        <button type="button" class="btn btn--danger" style="padding:0.4rem 0.6rem;" onclick="removePrintSize(${i})">✕</button>
      `;
      editor.appendChild(row);
    });
    input.value = JSON.stringify(printSizes);
  }

  window.addPrintSize = function () {
    printSizes.push({ label: '', price: 0 });
    renderPrintSizes();
  };

  window.updatePrintSize = function (i, field, value) {
    printSizes[i][field] = value;
    document.getElementById('printSizes').value = JSON.stringify(printSizes);
  };

  window.removePrintSize = function (i) {
    printSizes.splice(i, 1);
    renderPrintSizes();
  };

  document.getElementById('artwork-form')?.addEventListener('submit', () => {
    document.getElementById('printSizes').value = JSON.stringify(printSizes);
  });

  // Initialize
  renderPrintSizes();
</script>
