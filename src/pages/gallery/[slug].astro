---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { connectDB } from '../../lib/db';
import { Artwork } from '../../lib/models/Artwork';

const { slug } = Astro.params;
await connectDB();
const artwork = await Artwork.findOne({ slug }).lean();

if (!artwork) return Astro.redirect('/gallery');

const displayPrice = artwork.price != null
  ? `€${artwork.price.toLocaleString()}`
  : null;

const cartData = {
  id: String(artwork._id),
  slug: artwork.slug,
  title: artwork.title,
  thumbnailUrl: artwork.thumbnailUrl,
  price: artwork.price,
  priceLabel: displayPrice || (artwork.printSizes[0] ? `€${artwork.printSizes[0].price.toLocaleString()}` : ''),
};

const printOptions = artwork.printSizes.map(ps => ({
  label: ps.label,
  price: ps.price,
  priceLabel: `€${ps.price.toLocaleString()}`,
}));
---

<BaseLayout
  title={artwork.title}
  description={artwork.description || `${artwork.medium} · ${artwork.year}`}
  image={artwork.imageUrl}
>
  <div class="container">
    <div class="artwork-detail">
      <div class="artwork-detail__image">
        <img
          src={artwork.imageUrl}
          alt={artwork.title}
          width="960"
          height="1280"
        />
      </div>

      <div class="artwork-detail__info">
        <p class="artwork-detail__category">
          {artwork.category === 'drawing' ? 'Drawing' : 'Photography'}
        </p>

        <h1 class="artwork-detail__title">{artwork.title}</h1>

        {artwork.available && (displayPrice || artwork.printSizes.length > 0) && (
          <p class="artwork-detail__price-tag">
            {displayPrice ?? `From €${Math.min(...artwork.printSizes.map(p => p.price)).toLocaleString()}`}
          </p>
        )}
        {!artwork.available && <span class="sold-badge" style="align-self:flex-start;">Sold</span>}

        {artwork.medium && (
          <p class="artwork-detail__meta">{artwork.medium}</p>
        )}

        {artwork.description && (
          <div class="artwork-detail__description">
            {artwork.description}
          </div>
        )}

        <div class="artwork-detail__pricing">
          {artwork.available ? (
            <>
              {artwork.printSizes.length > 0 && (
                <div>
                  <p class="pricing-label">Prints available</p>
                  <div class="print-sizes">
                    {artwork.printSizes.map((ps) => (
                      <div class="print-size-row">
                        <span class="print-size-label">{ps.label}</span>
                        <span class="print-size-price">€{ps.price.toLocaleString()}</span>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {!displayPrice && artwork.printSizes.length === 0 && (
                <p style="color:var(--text-muted);font-size:0.9375rem;">
                  Contact for pricing
                </p>
              )}
            </>
          ) : null}
        </div>

        {artwork.available && (displayPrice || artwork.printSizes.length > 0) && (
          <div class="artwork-detail__add-cart">
            {artwork.printSizes.length > 0 && (
              <select class="cart-select" id="cart-option">
                {displayPrice && (
                  <option value="original" data-price={artwork.price} data-label="">
                    Original — {displayPrice}
                  </option>
                )}
                {artwork.printSizes.map((ps) => (
                  <option value={ps.label} data-price={ps.price} data-label={ps.label}>
                    Print {ps.label} — €{ps.price.toLocaleString()}
                  </option>
                ))}
              </select>
            )}
            <button class="btn btn--cart" id="add-to-cart-btn">
              Add to cart
            </button>
          </div>
        )}

        {artwork.tags.length > 0 && (
          <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:0.5rem;">
            {artwork.tags.map((tag) => (
              <span style="padding:0.25rem 0.625rem;border:1px solid var(--border);font-size:0.75rem;color:var(--text-muted);letter-spacing:0.04em;">
                {tag}
              </span>
            ))}
          </div>
        )}

        <a href="/gallery" style="display:inline-block;margin-top:1rem;font-size:0.8125rem;letter-spacing:0.06em;color:var(--text-muted);text-transform:uppercase;">
          ← Back to gallery
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ cartData, printOptions }}>
  const btn = document.getElementById('add-to-cart-btn');
  const select = document.getElementById('cart-option');

  if (btn) {
    btn.addEventListener('click', () => {
      let item = { ...cartData };

      if (select) {
        const opt = select.options[select.selectedIndex];
        const optLabel = opt.dataset.label;
        const optPrice = opt.dataset.price ? Number(opt.dataset.price) : null;
        if (optLabel) {
          item.optionLabel = optLabel;
          item.price = optPrice;
          item.priceLabel = optPrice != null ? `€${optPrice.toLocaleString()}` : cartData.priceLabel;
        }
      }

      if (typeof window.addToCart === 'function') {
        window.addToCart(item);
      }
    });
  }
</script>
