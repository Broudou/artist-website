---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { connectDB } from '../lib/db';
import { SiteContent } from '../lib/models/SiteContent';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

await connectDB();
const content = await SiteContent.findOne({ key: 'homepage' }).lean();
const artistName = content?.artistName || 'Artist Portfolio';
const tagline = content?.tagline || '';
const instagramUrl = content?.instagramUrl || '';

const {
  title = artistName,
  description = tagline,
  image,
} = Astro.props;

const pageTitle = title === artistName ? artistName : `${title} — ${artistName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    {image && <meta property="og:image" content={image} />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <Nav artistName={artistName} />

    <!-- Cart overlay + drawer -->
    <div class="cart-overlay" id="cart-overlay"></div>
    <aside class="cart-drawer" id="cart-drawer" aria-label="Shopping cart">
      <div class="cart-drawer__header">
        <h2 class="cart-drawer__title">Cart</h2>
        <button class="cart-close" id="cart-close" aria-label="Close cart">✕</button>
      </div>
      <div class="cart-items" id="cart-items"></div>
      <div class="cart-footer" id="cart-footer" hidden>
        <div class="cart-total">
          <span class="cart-total__label">Total</span>
          <span class="cart-total__amount" id="cart-total-amount">€0</span>
        </div>
        <a href="/contact" class="cart-inquiry" id="cart-inquiry">Send Inquiry</a>
      </div>
    </aside>

    <main class="page-content">
      <slot />
    </main>
    <Footer artistName={artistName} instagramUrl={instagramUrl} />
  </body>
</html>

<script>
  const CART_KEY = 'artist_cart';

  interface CartItem {
    id: string;
    slug: string;
    title: string;
    thumbnailUrl: string;
    price: number | null;
    priceLabel: string;
    optionLabel?: string;
  }

  function getCart(): CartItem[] {
    try { return JSON.parse(localStorage.getItem(CART_KEY) || '[]'); } catch { return []; }
  }

  function saveCart(items: CartItem[]) {
    localStorage.setItem(CART_KEY, JSON.stringify(items));
    renderCart();
    updateBadge();
  }

  function updateBadge() {
    const items = getCart();
    const btn = document.getElementById('cart-count');
    if (!btn) return;
    if (items.length > 0) {
      btn.textContent = String(items.length);
      btn.removeAttribute('hidden');
    } else {
      btn.setAttribute('hidden', '');
    }
  }

  function renderCart() {
    const items = getCart();
    const container = document.getElementById('cart-items')!;
    const footer = document.getElementById('cart-footer')!;
    const totalEl = document.getElementById('cart-total-amount')!;
    const inquiryBtn = document.getElementById('cart-inquiry') as HTMLAnchorElement;

    if (items.length === 0) {
      container.innerHTML = '<p class="cart-empty">Your cart is empty</p>';
      footer.hidden = true;
      return;
    }

    container.innerHTML = items.map((item, i) => `
      <div class="cart-item">
        <img class="cart-item__img" src="${item.thumbnailUrl}" alt="${item.title}" />
        <div>
          <p class="cart-item__title">${item.title}</p>
          ${item.optionLabel ? `<p class="cart-item__label">${item.optionLabel}</p>` : ''}
          <p class="cart-item__price">${item.priceLabel}</p>
        </div>
        <button class="cart-item__remove" data-index="${i}" aria-label="Remove">✕</button>
      </div>
    `).join('');

    container.querySelectorAll('.cart-item__remove').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = Number((btn as HTMLElement).dataset.index);
        const updated = getCart();
        updated.splice(idx, 1);
        saveCart(updated);
      });
    });

    const total = items.reduce((sum, item) => sum + (item.price ?? 0), 0);
    totalEl.textContent = total > 0 ? `€${total.toLocaleString()}` : '—';
    footer.hidden = false;

    // Pre-fill inquiry link with cart contents
    const titles = items.map(i => `- ${i.title}${i.optionLabel ? ` (${i.optionLabel})` : ''} ${i.priceLabel}`).join('\n');
    inquiryBtn.href = `/contact?items=${encodeURIComponent(titles)}`;
  }

  function openCart() {
    document.getElementById('cart-drawer')!.classList.add('open');
    document.getElementById('cart-overlay')!.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeCart() {
    document.getElementById('cart-drawer')!.classList.remove('open');
    document.getElementById('cart-overlay')!.classList.remove('open');
    document.body.style.overflow = '';
  }

  // Expose globally so artwork pages can call it
  (window as any).addToCart = function(item: CartItem) {
    const cart = getCart();
    cart.push(item);
    saveCart(cart);
    openCart();
  };

  (window as any).openCart = openCart;

  document.getElementById('cart-toggle')?.addEventListener('click', openCart);
  document.getElementById('cart-close')?.addEventListener('click', closeCart);
  document.getElementById('cart-overlay')?.addEventListener('click', closeCart);

  // Init on load
  renderCart();
  updateBadge();
</script>
