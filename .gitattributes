# Normalize line endings to LF on commit (cross-platform consistency)
* text=auto eol=lf

# Windows batch files must keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line-ending normalization
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.svg text
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
